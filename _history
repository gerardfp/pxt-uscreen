  led.toggle(x, y)\n})\n","README.md":"","pxt.json":"{\n    \"name\": \"lightsout\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"MakerBit-Pins\": \"github:1010technologies/pxt-makerbit-pins#v1.2.0\",\n        \"neopixel\": \"github:microsoft/pxt-neopixel#v0.7.6\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1781697013628,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"WKJ!HJU@xEts!uS;}HUy\">x</variable><variable id=\"*[ksOh/02RW=2z|K/^=*\">y</variable><variable id=\"S(b9eRUyz$KV$_Ssc11H\">state</variable><variable id=\"6^(hS5?tq0TW_%GsgTEa\">i</variable><variable id=\"?gphxZeBD,M@sbSV|9@L\">j</variable><variable id=\"m70zF;fp.`m3k#KbA?WP\">k</variable><variable id=\"TDd174]aeRMb+~$+{7R|\">l</variable></variables><block type=\"device_button_event\" x=\"457\" y=\"-36\"><field name=\"NAME\">Button.B</field><statement name=\"HANDLER\"><block type=\"device_plot_brightness\"><value name=\"x\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"4\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"WKJ!HJU@xEts!uS;}HUy\">x</field></block></value><value name=\"y\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"4\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"*[ksOh/02RW=2z|K/^=*\">y</field></block></value><value name=\"brightness\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"255\" precision=\"0\"></mutation><field name=\"SLIDER\">0</field></shadow><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"variables_get\"><fie