lDown)\npins.setPull(DigitalPin.P14, PinPullMode.PullDown)\npins.setPull(DigitalPin.P16, PinPullMode.PullDown)\nbasic.clearScreen()\nbasic.forever(function () {\n    for (let y = 0; y <= 2; y++) {\n        for (let x = 0; x <= 2; x++) {\n            pressed = scanButton(x, y)\n            // Detectar flanco de subida\n            if (pressed) {\n                toggleLed(x, y)\n                \n            }\n        }\n    }\n})\n","README.md":"","pxt.json":"{\n    \"name\": \"lightsout\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"MakerBit-Pins\": \"github:1010technologies/pxt-makerbit-pins#v1.2.0\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1781684374334,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"D;JZUGk`t0o3t9PG2qZ@\">led0</variable><variable id=\"@VwcO~SAUi8?$WziqsFR\">x</variable><variable id=\"6$%ecQTT:fSnI7tZ7z-5\">led1</variable><variable id=\"pf?XaC?;p?@mi4Sm+W@}\">p</variable><variable id=\"gay5:E3xT$~@c,vG+U:2\">led2</variable><variable id=\"Nw{[:$+quXIpavPEd/J[\">led3</variable><variable id=\"v.iLdCg)N4B{uMdd6ijN\">led4</variable><variable id=\"2ue+;hv)!XJLq0oyO@l*\">led5</variable><variable id=\"8I6R)Q+xoediGK8v?34^\">led6</variable><variable id=\"~LQxw]KU)5;bOwPafN8o\">led7</variable><variable id=\"_I@MR2yN*H*0Zl6DR;Kl\">strip</variable></variables><block type=\"pxt-on-start\" x=\"6\" y=\"-280\"><statement name=\"HANDLER\"><block type=\"variables_set\"><field name=\"VAR\" id=\"_I@MR2yN*H*0Zl6DR;Kl\">strip</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"neopixel_create\"><field name=\"pin\">DigitalPin.P8</field><field name=\"mode\">NeoPixelMode.RGB</field><value name=\"numleds\"><sha